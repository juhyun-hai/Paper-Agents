[Unit]
Description=Ollama Local LLM Runtime
After=network.target

[Service]
Type=simple
Environment="PATH=/home/juhyun/.local/bin:/usr/local/bin:/usr/bin:/bin"
Environment="OLLAMA_HOST=127.0.0.1:11434"
Environment="OLLAMA_MODELS=/home/juhyun/.ollama/models"
ExecStart=/home/juhyun/.local/bin/ollama serve
# 정상 종료(code=0)도 재시작 — 실수로 stop 되거나 auto-shutdown 시 방어.
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
